generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ClientStatus {
  new
  active
  inactive
  debt
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  completed
  no_show
}

enum PaymentStatus {
  paid
  partial
  unpaid
}

enum PaymentMethod {
  cash
  bit
  paybox
  credit
  transfer
  check
}

enum DebtStatus {
  open
  partial
  closed
}

enum ReceiptStatus {
  active
  cancelled
}

enum ExpenseCategory {
  materials
  equipment
  furniture
  marketing
  training
  utilities
  rent
  taxes
  hygiene
  other
}

model BusinessSettings {
  id                    String   @id @default(cuid())
  businessName          String   @default("NoyaGayaEzon")
  ownerName             String?
  businessNumber        String?
  phone                 String?
  email                 String?
  address               String?
  logoUrl               String?
  receiptStartingNumber Int      @default(1000)
  receiptFooterText     String?  @default("תודה על הביקור!")
  taskReminderMinutes   Int      @default(30)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("business_settings")
}

model Treatment {
  id                     String   @id @default(cuid())
  name                   String
  description            String?
  defaultPrice           Float    @default(0)
  durationMinutes        Int      @default(60)
  bufferMinutes          Int      @default(15)
  isActive               Boolean  @default(true)
  color                  String   @default("#D4A0A0")
  studentDiscountEnabled Boolean  @default(false)
  studentDiscountPercent Float    @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  appointments Appointment[]
  visits       Visit[]

  @@map("treatments")
}

model Addon {
  id        String   @id @default(cuid())
  name      String
  price     Float    @default(0)
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("addons")
}

model Client {
  id            String       @id @default(cuid())
  fullName      String
  phone         String?
  email         String?
  city          String?
  address       String?
  notes         String?
  preferences   String?
  sensitivities String?
  status        ClientStatus @default(new)
  cardOpenedAt  DateTime     @default(now())
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  appointments Appointment[]
  visits       Visit[]
  payments     Payment[]
  debts        Debt[]
  receipts     Receipt[]

  @@map("clients")
}

model WorkHours {
  id        String  @id @default(cuid())
  dayOfWeek Int
  isWorking Boolean @default(true)
  startTime String  @default("09:00")
  endTime   String  @default("18:00")

  @@unique([dayOfWeek])
  @@map("work_hours")
}

model BlockedTime {
  id         String   @id @default(cuid())
  startAt    DateTime
  endAt      DateTime
  reason     String?
  isVacation Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("blocked_times")
}

model AvailabilitySettings {
  id                    String @id @default(cuid())
  minBookingHours       Int    @default(24)
  maxAppointmentsPerDay Int?
  slotIntervalMinutes   Int    @default(15)

  @@map("availability_settings")
}

model Appointment {
  id              String            @id @default(cuid())
  clientId        String?
  treatmentId     String?
  guestName       String?
  guestPhone      String?
  guestEmail      String?
  startAt         DateTime
  endAt           DateTime
  price           Float?
  notes           String?
  status          AppointmentStatus @default(pending)
  addonIds        String[]          @default([])
  isStudentDiscount Boolean         @default(false)
  cancelledReason String?
  cancelledAt     DateTime?
  confirmedAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  client    Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  treatment Treatment? @relation(fields: [treatmentId], references: [id], onDelete: SetNull)
  visit     Visit?

  @@map("appointments")
}

model Visit {
  id            String        @id @default(cuid())
  clientId      String
  appointmentId String?       @unique
  treatmentId   String?
  treatmentName String
  visitedAt     DateTime
  price         Float         @default(0)
  notes         String?
  paymentStatus PaymentStatus @default(unpaid)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  treatment   Treatment?   @relation(fields: [treatmentId], references: [id], onDelete: SetNull)
  payments    Payment[]
  debts       Debt[]
  receipts    Receipt[]

  @@map("visits")
}

model Payment {
  id        String        @id @default(cuid())
  clientId  String
  visitId   String?
  amount    Float
  method    PaymentMethod @default(cash)
  reference String?
  notes     String?
  paidAt    DateTime      @default(now())
  createdAt DateTime      @default(now())

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  visit   Visit?   @relation(fields: [visitId], references: [id], onDelete: SetNull)
  receipt Receipt?

  @@map("payments")
}

model Debt {
  id             String     @id @default(cuid())
  clientId       String
  visitId        String?
  originalAmount Float
  paidAmount     Float      @default(0)
  status         DebtStatus @default(open)
  notes          String?
  reminderAt     DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  visit  Visit? @relation(fields: [visitId], references: [id], onDelete: SetNull)

  @@map("debts")
}

model Receipt {
  id                 String        @id @default(cuid())
  clientId           String
  visitId            String?
  paymentId          String?       @unique
  receiptNumber      Int           @unique
  amount             Float
  method             PaymentMethod
  serviceDescription String
  clientName         String
  addons             Json?
  discountAmount     Float         @default(0)
  discountLabel      String?
  status             ReceiptStatus @default(active)
  cancelledAt        DateTime?
  cancellationReason String?
  deletedAt          DateTime?
  issuedAt           DateTime      @default(now())
  createdAt          DateTime      @default(now())

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  visit   Visit?   @relation(fields: [visitId], references: [id], onDelete: SetNull)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@map("receipts")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueAt       DateTime?
  completedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("tasks")
}

model Expense {
  id          String          @id @default(cuid())
  category    ExpenseCategory
  description String
  amount      Float
  date        DateTime        @default(now())
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("expenses")
}
